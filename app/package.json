{
  "name": "evotempus-app",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "webpack serve --mode development --config ./config/webpack.dev.js",
    "build": "webpack --mode production --config ./config/webpack.prod.js",
    "build:dev": "webpack --mode production --env config=development --config ./config/webpack.dev.js",
    "build:dev:stats": "webpack --mode production --env config=development --config ./config/webpack.dev.js --profile --json > stats.json",
    "build:prod": "IMAGE_INLINE_SIZE_LIMIT=0 INLINE_RUNTIME_CHUNK=false pnpm run build",
    "lint": "clear && eslint --ext .ts,.tsx ./src",
    "lint:fix": "clear && eslint --fix --ext .ts,.tsx ./src",
    "format:check": "yarn prettier --check 'src/**/*.{ts,tsx,css,md,json}'",
    "format:fix": "yarn prettier --write 'src/**/*.{ts,tsx,css,md,json}'",
    "test": "jest --coverage src/**/*.test.ts*",
    "test:watch": "jest --watch --verbose --coverage"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
