{
  "name": "evotempus-app",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "webpack serve --mode development --config ./config/webpack.dev.js",
    "build": "webpack --mode production --config ./config/webpack.prod.js",
    "build:dev": "webpack --mode production --env config=development --config ./config/webpack.dev.js",
    "build:dev:stats": "webpack --mode production --env config=development --config ./config/webpack.dev.js --profile --json > stats.json",
    "build:prod": "IMAGE_INLINE_SIZE_LIMIT=0 INLINE_RUNTIME_CHUNK=false pnpm run build",
    "lint": "clear && eslint --ext .ts,.tsx ./src",
    "lint:fix": "clear && eslint --fix --ext .ts,.tsx ./src",
    "format:check": "yarn prettier --check 'src/**/*.{ts,tsx,css,md,json}'",
    "format:fix": "yarn prettier --write 'src/**/*.{ts,tsx,css,md,json}'",
    "test": "jest --coverage src/**/*.test.ts*",
    "test:watch": "jest --watch --verbose --coverage=false --silent=false",
    "check:deps": "pnpm dlx knip --dependencies"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@juggle/resize-observer": "^3.4.0",
    "@react-hook/latest": "^1.0.3",
    "@react-hook/passive-layout-effect": "^1.2.1",
    "@react-hook/resize-observer": "^2.0.2",
    "@react-spring/animated": "^10.0.3",
    "@react-spring/core": "^10.0.3",
    "@react-spring/rafz": "^10.0.3",
    "@react-spring/shared": "^10.0.3",
    "@react-spring/types": "^10.0.3",
    "@react-spring/web": "^10.0.3",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.15.2",
    "bootstrap": "^5.3.8",
    "color-hash": "^2.0.2",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-color": "^3.1.0",
    "d3-dispatch": "^3.0.1",
    "d3-drag": "^3.0.0",
    "d3-ease": "^3.0.1",
    "d3-fetch": "^3.0.1",
    "d3-format": "^3.1.2",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-path": "^3.1.0",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "d3-timer": "^3.0.1",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "lodash.clonedeep": "^4.5.0",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bootstrap": "^5.2.10",
    "@types/color-hash": "^2.0.0",
    "@types/d3-array": "^3.2.2",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-color": "^3.1.3",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/jest": "^30.0.0",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "dotenv-webpack": "^8.1.1",
    "eslint": "^9.39.4",
