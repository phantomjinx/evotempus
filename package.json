{
  "name": "evotempus",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:app": "pnpm --filter evotempus-app run dev",
    "dev:backend": "pnpm --filter evotempus-backend run dev:start",
    "dev": "pnpm run dev:app & pnpm run dev:backend",
    "build:app": "pnpm --filter evotempus-app run build:prod",
    "build:backend": "pnpm --filter evotempus-backend run build",
    "start": "./production/run-prod-local.sh",
    "license:check": "node scripts/license-header.mjs",
    "license:fix": "node scripts/license-header.mjs --fix",
    "lint:app": "pnpm --filter evotempus-app run lint",
    "lint:backend": "pnpm --filter evotempus-backend run lint",
    "lint": "pnpm run lint:app & pnpm run lint:backend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phantomjinx/evotempus.git"
  },
  "author": "phantomjinx",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/phantomjinx/evotempus/issues"
  },
  "homepage": "https://github.com/phantomjinx/evotempus#readme",
  "pnpm": {
    "overrides": {
      "mongodb": "^7.1.0",
      "@typescript-eslint/eslint-plugin": "^8.56.1",
      "@typescript-eslint/parser": "^8.56.1"
    }
  }
}
